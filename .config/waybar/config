{
  "layer": "top",
  "position": "bottom",
  "spacing": 5,
  "margin": 0,
  "passthrough": false,
  "reload_style_on_change": true,
  "height": 30,

  "modules-left": [
    "custom/files",
    "custom/terminal",
    "custom/firefox",
    "custom/steam",
    "custom/lutris",
    "custom/discord",
    "wlr/taskbar"
  ],

  "modules-center": [],

  "modules-right": [
    "network",
    "cpu",
    "memory",
    "pulseaudio",
    "tray",
    "clock#date",
    "clock#time",
    "custom/power"
  ],

  // ---------------- CUSTOM APPS ----------------

  "custom/firefox": {
    "format": "’ē®",
    "on-click": "librewolf",
    "tooltip": false
  },

  "custom/terminal": {
    "format": "’äĀ",
    "on-click": "foot",
    "tooltip": false
  },

  "custom/steam": {
    "format": "’åČ",
    "on-click": "steam-native",
    "tooltip": false
  },

  "custom/files": {
    "format": "’ü╝",
    "on-click": "thunar",
    "tooltip": false
  },

  "custom/discord": {
    "format": "’ÄÆ",
    "on-click": "vesktop",
    "tooltip": false
  },

  "custom/lutris": {
    "format": "’äø",
    "on-click": "lutris",
    "tooltip": false
  },

  // ---------------- CLOCK ----------------

  "clock#time": {
    "interval": 1,
    "format": "{:%H:%M}",
    "timezone": "Europe/Paris",
    "tooltip": false
  },

  "clock#date": {
    "format": "’ü│  {:%d %b %Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  // ---------------- SYSTEM ----------------

  "cpu": {
    "interval": 3,
    "format": "’ŗø {usage}%",
    "format-alt": "’ŗø {usage}% ({load})",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  "memory": {
    "interval": 3,
    "format": "’öĖ  {percentage}%", 
    "format-alt": "’öĖ {used}Go",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  // ---------------- NETWORK ----------------

  "network": {
    "interval": 3,
    "format-wifi": "’ć½ {bandwidthDownBytes}",
    "format-ethernet": "’×¢ {bandwidthDownBytes}",
    "format-disconnected": "ŌÜĀ Offline",
    "tooltip-format": "{ifname} ŌĆó {ipaddr}"
  },

  // ---------------- AUDIO ----------------

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "’Ć”",
    "format-icons": {
      "default": ["’Ć¦", "’Ć©"]
    },
    "on-click": "pavucontrol"
  },

  // ---------------- TASKBAR ----------------

  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 16,
    "tooltip-format": "{title}",
    "on-click": "minimize-raise",
    "on-click-middle": "close"
  },

  // ---------------- TRAY ----------------

  "tray": {
    "icon-size": 18,
    "spacing": 8
  },

  // ---------------- POWER ----------------

  "custom/power": {
    "format": "ŌÅ╗",
    "tooltip": false,
    "on-click": "wlogout"
  }
}